"requisition_id":"290","location":"Fully Remote, South Africa | Poland | Netherlands | Norway | Estonia | Ireland","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5802574004","published_at":"2026-03-12T08:51:21-04:00","department":{"name":"Technology Operations","id":4063101004,"path":["Operations"]},"is_featured":false},{"id":5970472004,"title":"Senior Systems Administrator","internal_job_id":5142495004,"updated_at":"2026-04-17T08:36:21-04:00","requisition_id":"303","location":"Oslo, Norway","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5970472004","published_at":"2026-04-17T08:12:31-04:00","department":{"name":"Operations Engineering","id":4023897004,"path":["Operations","Technology Operations"]},"is_featured":false},{"id":5850890004,"title":"MySQL Database Engineer","internal_job_id":5074708004,"updated_at":"2026-04-17T08:36:21-04:00","requisition_id":"302","location":"Fully Remote, South Africa","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5850890004","published_at":"2026-04-14T09:17:04-04:00","department":{"name":"Platform, Hosting, Shared Service","id":4077798004,"path":["Operations","Technology Operations"]},"is_featured":false},{"id":5734712004,"title":"Senior Software Engineer: Authentication Advice","internal_job_id":5018599004,"updated_at":"2026-04-17T08:36:21-04:00","requisition_id":"280","location":"Fully Remote, South Africa","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5734712004","published_at":"2025-12-22T04:44:35-05:00","department":{"name":"Advice \u0026 Intelligence","id":4063098004,"path":["Product Development"]},"is_featured":false},{"id":5820545004,"title":"Senior Product Manager – Digital Banking","internal_job_id":5060292004,"updated_at":"2026-04-17T08:36:21-04:00","requisition_id":"296","location":"1155 Mt Vernon Hwy NE, Atlanta, GA 30338","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5820545004","published_at":"2026-03-06T08:47:51-05:00","department":{"name":"Authentication Journeys","id":4077797004,"path":["Product Development"]},"is_featured":false},{"id":5844534004,"title":"Senior Quality Engineer: Automation \u0026 Integration Testing","internal_job_id":5072002004,"updated_at":"2026-04-17T08:36:21-04:00","requisition_id":"301","location":"Fully Remote, South Africa","absolute_url":"https://job-boards.greenhouse.io/entersekt/jobs/5844534004","published_at":"2026-04-08T05:43:57-04:00","department":{"name":"QE \u0026 Agile Delivery","id":4046269004,"path":["Product Development"]},"is_featured":false}]},"featuredPosts":{"data":[]},"board":{"name":"Entersekt","public_url":"https://job-boards.greenhouse.io/entersekt","content":"\u003cdiv\u003e\u003cimg style=\"width: 100%; max-width: 100%;\" src=\"https://info.entersekt.com/hubfs/Greenhouse%20mailer%20template%20banner.jpg\"\u003e\u003c/div\u003e\n\u003cp style=\"margin-bottom: 0px; margin-top: 0px;\"\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp style=\"margin-bottom: 0px; margin-top: 0px;\"\u003e\u003cspan style=\"color: #324375; font-weight: bold;\"\u003eWhy Entersekt\u003c/span\u003e\u003c/p\u003e\n\u003cp style=\"margin-bottom: 0px; margin-top: 0px;\"\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp style=\"margin-bottom: 0px; margin-top: 0px;\"\u003eFounded over 16 years ago, with more recent investments from Accel-KKR, Entersekt is a leader in digital banking fraud prevention and payment security, including mobile authentication, mobile app security, and 3D Secure authentication for issuers, acquirers and payment networks. We offer highly scalable products with a track record of success across multiple continents.\u003c/p\u003e\n\u003cp style=\"margin-bottom: 0px; margin-top: 0px;\"\u003e\u003cbr\u003eEntersekt enables secure digital transactions for leading financial institutions globally. We exist to create a world where everyone can transact digitally without fear or compromise. Currently, we protect the digital transactions of over 210 million active users on our platform and hold 120 active patents that recognize innovation in digital security, payments, and user experience. Entersekt offers customers secure authentication and digital payments experiences that remove unnecessary friction. Entersekt has a diverse product portfolio and aggressive roadmap that positions the company well to sustain competitive advantage as it expands globally with emphasis on North America and European markets.\u003c/p\u003e","redirect_to":null},"departments":[{"id":4023895004,"value":4023895004,"name":"Commercial","label":"Commercial","children":[]},{"id":4119297004,"value":4119297004,"name":"Operations","label":"Operations","children":[{"id":4077786004,"value":4077786004,"name":"Client Operations","label":"Client Operations","children":[]},{"id":4063101004,"value":4063101004,"name":"Technology Operations","label":"Technology Operations","children":[{"id":4023897004,"value":4023897004,"name":"Operations Engineering","label":"Operations Engineering","children":[]},{"id":4077798004,"value":4077798004,"name":"Platform, Hosting, Shared Service","label":"Platform, Hosting, Shared Service","children":[]}]}]},{"id":4023898004,"value":4023898004,"name":"Product Development","label":"Product Development","children":[{"id":4063098004,"value":4063098004,"name":"Advice \u0026 Intelligence","label":"Advice \u0026 Intelligence","children":[]},{"id":4077797004,"value":4077797004,"name":"Authentication Journeys","label":"Authentication Journeys","children":[]},{"id":4046269004,"value":4046269004,"name":"QE \u0026 Agile Delivery","label":"QE \u0026 Agile Delivery","children":[]}]}],"recentlyLiveDepartments":[{"id":4063098004,"value":4063098004,"name":"Advice \u0026 Intelligence","label":"Advice \u0026 Intelligence"},{"id":4077797004,"value":4077797004,"name":"Authentication Journeys","label":"Authentication Journeys"},{"id":4077786004,"value":4077786004,"name":"Client Operations","label":"Client Operations"},{"id":4023895004,"value":4023895004,"name":"Commercial",