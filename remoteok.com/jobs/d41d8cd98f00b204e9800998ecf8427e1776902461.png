:{"name":"Cloud Data Engineering","id":4034284004,"path":["Service Delivery"]},"is_featured":false},{"id":4985682004,"title":"Senior Data Architect","internal_job_id":4299054004,"updated_at":"2026-04-22T16:38:35-04:00","requisition_id":"91","location":"ARGENTINA","absolute_url":"https://job-boards.greenhouse.io/caylent/jobs/4985682004","published_at":"2023-09-28T13:37:47-04:00","department":{"name":"Cloud Data Engineering","id":4034284004,"path":["Service Delivery"]},"is_featured":false},{"id":4985684004,"title":"Senior Data Architect","internal_job_id":4299054004,"updated_at":"2026-04-22T16:38:35-04:00","requisition_id":"91","location":"MEXICO","absolute_url":"https://job-boards.greenhouse.io/caylent/jobs/4985684004","published_at":"2023-09-28T13:39:29-04:00","department":{"name":"Cloud Data Engineering","id":4034284004,"path":["Service Delivery"]},"is_featured":false}]},"featuredPosts":{"data":[]},"board":{"name":"Caylent","public_url":"https://job-boards.greenhouse.io/caylent","content":"\u003ctable style=\"height: 680.938px; width: 701px;\" border=\"0\" width=\"938\"\u003e\n\u003ctbody\u003e\n\u003ctr style=\"height: 663.344px;\"\u003e\n\u003ctd style=\"width: 686.203px; height: 663.344px;\"\u003e\n\u003cp style=\"text-align: justify;\"\u003eCaylent is a Cloud Native services provider serving technology-enabled companies ranging from venture-backed startups to Fortune 500 enterprises. Our employees enjoy being on the cutting edge of technology while enjoying our fully-remote company and culture. \u003cbr\u003e\u003cbr\u003eWith employees from over 16 different countries and women well-represented on our leadership team, we like to think that we’re a different kind of tech company. Made up of employees who have come from other top cloud consulting partners and cutting-edge companies, we saw that there was a better way – one that included diversity, a genuinely helpful culture and most of all – fun. We take the work we do very seriously, but never ourselves.\u0026nbsp;\u003c/p\u003e\n\u003cp style=\"text-align: justify;\"\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e\u003ciframe style=\"width: 765px; height: 429px; display: table; margin-left: auto; margin-right: auto;\" src=\"https://www.youtube.com/embed/zB5ljdwiiXo\" width=\"765\" height=\"429\"\u003e\u003c/iframe\u003e\u003c/p\u003e\n\u003c/td\u003e\n\u003c/tr\u003e\n\u003ctr style=\"height: 17.5938px;\"\u003e\n\u003ctd style=\"width: 686.203px; height: 17.5938px;\"\u003e\u0026nbsp;\u003c/td\u003e\n\u003c/tr\u003e\n\u003c/tbody\u003e\n\u003c/table\u003e\n\u003cdiv data-id=\"1408260e\" data-element_type=\"column\"\u003e\n\u003cdiv\u003e\n\u003cdiv\u003e\n\u003cdiv data-id=\"3b871b44\" data-element_type=\"widget\" data-widget_type=\"heading.default\"\u003e\n\u003cdiv\u003e\u0026nbsp;\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003cdiv data-id=\"765b3ef9\" data-element_type=\"column\"\u003e\n\u003cdiv\u003e\n\u003cdiv\u003e\n\u003cdiv data-id=\"19050a48\" data-element_type=\"widget\" data-widget_type=\"text-editor.default\"\u003e\n\u003cdiv\u003e\n\u003cdiv\u003e\n\u003cdiv data-id=\"335ef1b\" data-element_type=\"column\" data-settings=\"{\u0026quot;background_background\u0026quot;:\u0026quot;classic\u0026quot;}\"\u003e\n\u003cdiv\u003e\n\u003cdiv\u003e\n\u003cdiv data-id=\"55c40ed\" data-element_type=\"widget\" data-widget_type=\"spacer.default\"\u003e\n\u003cdiv\u003e\u0026nbsp;\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e","redirect_to":null},"departments":[{"id":4124227004,"value":4124227004,"name":"Anthropic Consulting and Engineering","label":"Anthropic Consulting and Engineering"},{"id":4058252004,"value":4058252004,"name":"Center for Customer Evolution","label":"Center for Customer Evolution"},{"id":4057676004,"value":4057676004,"name":"Cloud Architecture \u0026 Engineeri